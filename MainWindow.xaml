<Window x:Class="InScope.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="InScope - Procedure Document Builder"
        Height="650" Width="1000"
        MinHeight="400" MinWidth="600">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border x:Name="ProductionHeaderBar" Height="4" Background="#0078D4" Visibility="Collapsed"/>

        <Menu Grid.Row="1">
            <MenuItem Header="File">
                <MenuItem Header="Start New">
                    <MenuItem Header="Electrical" Click="StartNew_Click" Tag="Electrical"/>
                    <MenuItem Header="Hydraulic" Click="StartNew_Click" Tag="Hydraulic"/>
                    <MenuItem Header="Mechanical" Click="StartNew_Click" Tag="Mechanical"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Export to PDF" Click="ExportPdf_Click"/>
                <Separator/>
                <MenuItem Header="Exit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="Help">
                <MenuItem Header="Check for Updates" Click="CheckForUpdates_Click"/>
                <MenuItem Header="Open Log Folder" Click="OpenLogFolder_Click"/>
            </MenuItem>
        </Menu>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="200"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="10">
                <StackPanel x:Name="QuestionsPanel">
                    <TextBlock x:Name="QuestionsHeader" Text="Select a procedure type (File → Start New)" 
                               TextWrapping="Wrap" FontWeight="SemiBold" Margin="0,0,0,10"
                               Foreground="#666"/>
                </StackPanel>
            </ScrollViewer>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#ddd" ShowsPreview="True"/>

            <Border Grid.Column="2" BorderBrush="#ccc" BorderThickness="1" Margin="5">
                <RichTextBox x:Name="DocumentEditor" 
                             IsReadOnly="False"
                             Padding="10"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             AcceptsReturn="True"/>
            </Border>
        </Grid>

        <Grid Grid.Row="3" Height="24">
            <StatusBar>
                <StatusBarItem>
                    <TextBlock x:Name="StatusText" Text="Ready"/>
                </StatusBarItem>
                <Separator/>
                <StatusBarItem>
                    <TextBlock x:Name="ProcedureTypeText" Text="—"/>
                </StatusBarItem>
                <Separator/>
                <StatusBarItem>
                    <TextBlock x:Name="BlockCountText" Text="0 blocks"/>
                </StatusBarItem>
            </StatusBar>
            <TextBlock x:Name="VersionText" Text="v0.0.0" HorizontalAlignment="Right" VerticalAlignment="Center"
                       Margin="0,0,12,0" Foreground="#888" FontSize="11"/>
        </Grid>
    </Grid>
</Window>
