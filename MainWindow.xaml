<Window x:Class="InScope.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:InScope"
        Title="InScope - Procedure Document Builder"
        Height="650" Width="1000"
        MinHeight="400" MinWidth="600">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border x:Name="ProductionHeaderBar" Height="4" Background="{StaticResource AccentBrush}"
                Visibility="{Binding ProductionHeaderVisibility}"/>

        <Menu Grid.Row="1">
            <MenuItem Header="File">
                <MenuItem Header="Start New">
                    <MenuItem Header="Electrical" Command="{Binding StartNewCommand}" CommandParameter="{x:Static local:Constants.ProcedureTypeElectrical}"/>
                    <MenuItem Header="Hydraulic" Command="{Binding StartNewCommand}" CommandParameter="{x:Static local:Constants.ProcedureTypeHydraulic}"/>
                    <MenuItem Header="Mechanical" Command="{Binding StartNewCommand}" CommandParameter="{x:Static local:Constants.ProcedureTypeMechanical}"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Export to PDF" Command="{Binding ExportPdfCommand}"/>
                <Separator/>
                <MenuItem Header="Edit Questions…" Command="{Binding EditQuestionsCommand}"/>
                <MenuItem Header="Edit Block Library…" Command="{Binding EditBlockLibraryCommand}"/>
                <Separator/>
                <MenuItem Header="Exit" Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="Help">
                <MenuItem Header="Check for Updates" Command="{Binding CheckForUpdatesCommand}"/>
                <MenuItem Header="Open Log Folder" Command="{Binding OpenLogFolderCommand}"/>
                <MenuItem Header="Recover Block Backup…" Command="{Binding RecoverBlockBackupCommand}"/>
            </MenuItem>
        </Menu>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="200"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="10">
                <StackPanel>
                    <TextBlock Text="{Binding QuestionsHeader}"
                               TextWrapping="Wrap" FontWeight="SemiBold" Margin="0,0,0,10"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <ItemsControl ItemsSource="{Binding Questions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap" Margin="0,8,0,4"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Yes" Width="60" Margin="0,0,8,0"
                                                Command="{Binding YesCommand}"/>
                                        <Button Content="No" Width="60"
                                                Command="{Binding NoCommand}"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="{StaticResource SplitterBrush}" ShowsPreview="True"/>

            <Border Grid.Column="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="5">
                <RichTextBox x:Name="DocumentEditor"
                             IsReadOnly="False"
                             Padding="10"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             AcceptsReturn="True"/>
            </Border>
        </Grid>

        <Grid Grid.Row="3" Height="24">
            <StatusBar>
                <StatusBarItem>
                    <TextBlock Text="{Binding StatusText}"/>
                </StatusBarItem>
                <Separator/>
                <StatusBarItem>
                    <TextBlock Text="{Binding ProcedureTypeText}"/>
                </StatusBarItem>
                <Separator/>
                <StatusBarItem>
                    <TextBlock Text="{Binding BlockCountText}"/>
                </StatusBarItem>
            </StatusBar>
            <TextBlock Text="{Binding VersionText}" HorizontalAlignment="Right" VerticalAlignment="Center"
                       Margin="0,0,12,0" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
        </Grid>
    </Grid>
</Window>
