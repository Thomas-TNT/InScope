<Window x:Class="InScope.AddBlockDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Block"
        Height="220" Width="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Block ID:" Margin="0,0,0,4"/>
        <TextBox Grid.Row="1" Margin="0,0,0,16"
                 Text="{Binding BlockId, UpdateSourceTrigger=PropertyChanged}"
                 MaxLength="64" ToolTip="Alphanumeric and hyphens only (e.g. elec-005)"/>

        <TextBlock Grid.Row="2" Text="Section:" Margin="0,0,0,4"/>
        <ComboBox Grid.Row="3" Margin="0,0,0,16"
                  ItemsSource="{Binding Sections}"
                  SelectedItem="{Binding SelectedSection}"
                  IsEditable="False"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="80" Height="28" Margin="0,0,8,0" IsDefault="True" Command="{Binding OkCommand}"/>
            <Button Content="Cancel" Width="80" Height="28" IsCancel="True" Command="{Binding CancelCommand}"/>
        </StackPanel>
    </Grid>
</Window>
