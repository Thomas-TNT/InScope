<Window x:Class="InScope.BlockEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Block Library Editor"
        Height="550" Width="800"
        MinHeight="400" MinWidth="600"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="150"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="#ccc" BorderThickness="1" Margin="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,8,8,4">
                        <TextBlock Text="Blocks" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#333"/>
                        <Button x:Name="AddBlockButton" Content="Add" Margin="8,0,0,0" Padding="8,2" Click="AddBlock_Click"/>
                        <Button x:Name="DeleteBlockButton" Content="Delete" Margin="4,0,0,0" Padding="8,2" Click="DeleteBlock_Click"/>
                    </StackPanel>
                    <ListBox x:Name="BlockList"
                             Grid.Row="2"
                             SelectionChanged="BlockList_SelectionChanged"
                             DisplayMemberPath="BlockId"
                             Margin="4,0,4,4">
                        <ListBox.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#0078D4" Margin="0,8,0,4"/>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ListBox.GroupStyle>
                    </ListBox>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#ddd" ShowsPreview="True"/>

            <Border Grid.Column="2" BorderBrush="#ccc" BorderThickness="1" Margin="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="BlockFileNameText" Grid.Row="0" Text="Select a block" Margin="8,8,8,4" Foreground="#666"/>
                    <RichTextBox x:Name="DocumentEditor"
                                 Grid.Row="1"
                                 IsReadOnly="False"
                                 Padding="10"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 AcceptsReturn="True"
                                 Margin="4,0,4,4"/>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="8,4" HorizontalAlignment="Right">
            <Button x:Name="SaveButton" Content="Save" Width="80" Height="28" Margin="0,0,8,0" Click="Save_Click" IsEnabled="False"/>
            <Button x:Name="RevertButton" Content="Revert" Width="80" Height="28" Margin="0,0,8,0" Click="Revert_Click" IsEnabled="False"/>
            <Button Content="Close" Width="80" Height="28" IsCancel="True" Click="Close_Click"/>
        </StackPanel>

        <Border Grid.Row="2" Background="#f5f5f5" Padding="8,4">
            <TextBlock x:Name="StatusText" Text="Ready. Select a block to edit." TextWrapping="Wrap" Foreground="#666" FontSize="12"/>
        </Border>
    </Grid>
</Window>
