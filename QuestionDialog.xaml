<Window x:Class="InScope.QuestionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Question"
        Height="320" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Question ID:" Margin="0,0,0,4"/>
        <TextBox x:Name="IdBox" Grid.Row="1" Margin="0,0,0,12"
                 MaxLength="64" ToolTip="Alphanumeric, underscores, hyphens (e.g. UsesPump)"/>

        <TextBlock Grid.Row="2" Text="Question text:" Margin="0,0,0,4"/>
        <TextBox x:Name="TextBox" Grid.Row="3" Margin="0,0,0,8"
                 TextWrapping="Wrap" AcceptsReturn="True" Height="70" VerticalScrollBarVisibility="Auto"
                 ToolTip="The question shown to the user"/>

        <TextBlock Grid.Row="4" Text="Sections (procedure types):" Margin="0,0,0,4"/>
        <StackPanel x:Name="SectionsPanel" Grid.Row="5" Margin="0,0,0,8"/>

        <TextBlock Grid.Row="6" Text="Leave none selected for all sections." 
                   FontSize="11" Foreground="#666" Margin="0,0,0,8"/>

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="OK" Width="80" Height="28" Margin="0,0,8,0" IsDefault="True" Click="Ok_Click"/>
            <Button Content="Cancel" Width="80" Height="28" IsCancel="True" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
