<Window x:Class="InScope.RecoveryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Recover Block Backup"
        Height="450" Width="640"
        MinHeight="350" MinWidth="500"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Recent block changes with backups (Modified only)" 
                           FontWeight="SemiBold" Margin="8,8,8,4" Foreground="{StaticResource TextPrimaryBrush}"/>
                <ListView x:Name="EntriesList" Grid.Row="1" Margin="8,4,8,8"
                          SelectionChanged="EntriesList_SelectionChanged">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Timestamp" Width="160" DisplayMemberBinding="{Binding Timestamp}"/>
                            <GridViewColumn Header="Block" Width="120" DisplayMemberBinding="{Binding BlockId}"/>
                            <GridViewColumn Header="Action" Width="80" DisplayMemberBinding="{Binding Action}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="8,4" HorizontalAlignment="Right">
            <Button x:Name="RestoreButton" Content="Restore" Width="90" Height="28" Margin="0,0,8,0" 
                    Click="Restore_Click" IsEnabled="False"/>
            <Button x:Name="OpenFolderButton" Content="Open Backup Folder" Width="130" Height="28" Margin="0,0,8,0"
                    Click="OpenFolder_Click"/>
            <Button Content="Close" Width="80" Height="28" IsCancel="True" Click="Close_Click"/>
        </StackPanel>

        <Border Grid.Row="2" Style="{StaticResource StatusBarAreaBorderStyle}">
            <TextBlock x:Name="StatusText" Text="Backups are kept for 14 days. Select an entry and click Restore to recover a previous version." 
                       TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
        </Border>
    </Grid>
</Window>
