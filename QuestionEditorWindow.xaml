<Window x:Class="InScope.QuestionEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Question Editor"
        Height="450" Width="560"
        MinHeight="350" MinWidth="450"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,8,8,4">
                    <TextBlock Text="Questions" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <Button Content="Add" Margin="12,0,0,0" Padding="12,4" Command="{Binding AddCommand}"/>
                    <Button Content="Edit" Margin="4,0,0,0" Padding="12,4" Command="{Binding EditCommand}"/>
                    <Button Content="Delete" Margin="4,0,0,0" Padding="12,4" Command="{Binding DeleteCommand}"/>
                </StackPanel>
                <ListBox Grid.Row="1" Margin="8,4,8,8"
                         ItemsSource="{Binding Questions}"
                         SelectedItem="{Binding SelectedQuestion}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Id}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Text}" TextTrimming="CharacterEllipsis" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="8,4" HorizontalAlignment="Right">
            <Button Content="Save" Width="80" Height="28" Margin="0,0,8,0" Command="{Binding SaveCommand}"/>
            <Button Content="Close" Width="80" Height="28" IsCancel="True" Command="{Binding CloseRequestedCommand}"/>
        </StackPanel>

        <Border Grid.Row="2" Style="{StaticResource StatusBarAreaBorderStyle}">
            <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
        </Border>
    </Grid>
</Window>
