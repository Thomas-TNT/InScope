<Window x:Class="InScope.QuestionEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Question Editor"
        Height="450" Width="560"
        MinHeight="350" MinWidth="450"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="#ccc" BorderThickness="1" Margin="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,8,8,4">
                    <TextBlock Text="Questions" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#333"/>
                    <Button x:Name="AddButton" Content="Add" Margin="12,0,0,0" Padding="12,4" Click="Add_Click"/>
                    <Button x:Name="EditButton" Content="Edit" Margin="4,0,0,0" Padding="12,4" Click="Edit_Click"/>
                    <Button x:Name="DeleteButton" Content="Delete" Margin="4,0,0,0" Padding="12,4" Click="Delete_Click"/>
                </StackPanel>
                <ListBox x:Name="QuestionList" Grid.Row="1" Margin="8,4,8,8"
                         SelectionChanged="QuestionList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Id}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Text}" TextTrimming="CharacterEllipsis" Foreground="#666" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="8,4" HorizontalAlignment="Right">
            <Button x:Name="SaveButton" Content="Save" Width="80" Height="28" Margin="0,0,8,0" Click="Save_Click"/>
            <Button Content="Close" Width="80" Height="28" IsCancel="True" Click="Close_Click"/>
        </StackPanel>

        <Border Grid.Row="2" Background="#f5f5f5" Padding="8,4">
            <TextBlock x:Name="StatusText" Text="Add, edit, or delete questions. Click Save to persist changes." TextWrapping="Wrap" Foreground="#666" FontSize="12"/>
        </Border>
    </Grid>
</Window>
