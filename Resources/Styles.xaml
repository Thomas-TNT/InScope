<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Status bar area style (the gray footer strip used in MainWindow, BlockEditorWindow, QuestionEditorWindow) -->
    <Style x:Key="StatusBarAreaBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource StatusBarBackgroundBrush}"/>
        <Setter Property="Padding" Value="8,4"/>
    </Style>

    <!-- Section header (e.g. "Blocks", "Questions") -->
    <Style x:Key="SectionHeaderTextStyle" TargetType="TextBlock">
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <!-- Secondary/muted text -->
    <Style x:Key="SecondaryTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
    </Style>
</ResourceDictionary>
